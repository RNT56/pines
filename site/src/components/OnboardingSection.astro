---
const steps = [
  {
    number: "01",
    title: "Open a local chat",
    body: "Start with an on-device route so the first experience is useful before any provider keys are involved.",
  },
  {
    number: "02",
    title: "Choose a model and add context",
    body: "Review local model readiness, then bring in notes, PDFs, images, Markdown, JSON, CSV, or plain text when a task needs your material.",
  },
  {
    number: "03",
    title: "Expand only when useful",
    body: "Add BYOK providers, approval-aware tools, MCP servers, and Watch access as your workflow grows—not as setup tax on day one.",
  },
];
---

<section class="section onboarding" id="onboarding" aria-labelledby="onboarding-title">
  <div class="onboarding-copy">
    <span class="section-kicker">Getting Started</span>
    <h2 id="onboarding-title">Useful before you configure a single cloud service.</h2>
    <p>
      Pines is meant to feel calm on day one: begin locally, add your own material,
      then connect cloud providers and tools only when your workflow needs them.
    </p>
  </div>
  <div class="onboarding-steps">
    {steps.map((step) => (
      <article>
        <span>{step.number}</span>
        <h3>{step.title}</h3>
        <p>{step.body}</p>
      </article>
    ))}
  </div>
</section>
